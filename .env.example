# =========================================================================
# modular-ai-chat-app Environment Config Template
# =========================================================================

# --- BACKEND ENVIRONMENT VARIABLES (Copy to backend/.env) ---
# Database configuration (SQLite default)
DATABASE_URL=sqlite:///./sql_app.db

# Groq and OpenRouter API keys (Obtain from console.groq.com & openrouter.ai)
GROQ_API_KEY=gsk_your_groq_api_key_here
OPEN_ROUTER_API_KEY=sk-or-v1-your_open_router_api_key_here

# JWT Secret token key (Required for secure hashing, generate with `openssl rand -hex 32`)
JWT_SECRET=generate_a_random_hex_string_key_here_for_sessions

# Google OAuth2 Credentials (Obtain from Google Cloud Console APIs & Services)
GOOGLE_CLIENT_ID=785953439710-example.apps.com
GOOGLE_CLIENT_SECRET=GOCSPX-example_google_client_secret_here

# Allowed origins for API queries (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# --- FRONTEND ENVIRONMENT VARIABLES (Copy to frontend/.env) ---
# Base URL target for the FastAPI backend service
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID= 78595343971